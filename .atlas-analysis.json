  "publicApiSurface": [
    "POST /api/authenticate - JWT authentication",
    "GET /api/alerts - List security alerts",
    "GET /api/alerts/{id} - Get alert details",
    "PUT /api/alerts/{id} - Update alert status",
    "GET /api/utm-clients - List connected agents",
    "POST /api/utm-integration-conf - Configure integrations",
    "GET /api/utm-data-input-status - Get data source status",
    "GET /api/users - List users",
    "POST /api/users - Create user",
    "GET /api/account - Get current user account",
    "POST /api/account/change-password - Change password",
    "UTMStackAgent install - Install agent on endpoints",
    "UTMStackAgent enable-integration - Enable log collection",
    "UTMStackAgent disable-integration - Disable log collection"
  ]
